<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover">
    <meta name="description" content="{{ description or site.description }}">
    <meta name="keywords" content="{{ keywords or site.keywords }}">
    <meta name="author" content="{{ author or site.author.name }}">
    <meta name="robots" content="index, follow">
    
    <!-- Enhanced Open Graph -->
    <meta property="og:title" content="{{ title or site.title }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:type" content="{{ og_type or 'website' }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:image" content="{{ site.url }}/assets/images/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="{{ title or site.title }} - Portfolio de Oscar de la Cruz">
    <meta property="og:locale" content="es_ES">
    <meta property="og:site_name" content="{{ site.title }}">
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@{{ site.twitter or 'iosifstalin6773' }}">
    <meta name="twitter:creator" content="@{{ site.twitter or 'iosifstalin6773' }}">
    <meta name="twitter:title" content="{{ title or site.title }}">
    <meta name="twitter:description" content="{{ description or site.description }}">
    <meta name="twitter:image" content="{{ site.url }}/assets/images/og-image.jpg">
    
    <!-- Additional SEO -->
    <meta name="language" content="es">
    <meta name="geo.region" content="ES">
    <meta name="classification" content="Portfolio, Desarrollo Web, Gaming">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    
    <title>{{ title or site.title }}</title>
    
    <!-- Security Headers -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none';">
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="DENY">
    <meta http-equiv="X-XSS-Protection" content="1; mode=block">
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">
    <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()">
    
    <!-- HTTPS Enforcement -->
    <meta http-equiv="Strict-Transport-Security" content="max-age=31536000; includeSubDomains; preload">
    
    <!-- Preconnect to external domains for performance -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- DNS prefetch for external resources -->
    <link rel="dns-prefetch" href="//github.com">
    <link rel="dns-prefetch" href="//credly.com">
    <link rel="dns-prefetch" href="//mirrors.creativecommons.org">
    
    <!-- Preload critical resources -->
    <link rel="preload" href='{{ "/css/styles.css" | url }}' as="style">
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" as="style">
    
    <!-- Performance optimizations -->
    <meta name="format-detection" content="telephone=no">
    <meta name="theme-color" content="#1a1a1a">
    <link rel="icon" type="image/svg+xml" href='{{ "/assets/icons/website.svg" | url }}'>
    <link rel="icon" type="image/png" href='{{ "/assets/icons/favicon.png" | url }}'>
    
    <!-- Styles -->
    <link rel="stylesheet" href='{{ "/css/styles.css" | url }}'>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" crossorigin="anonymous" media="print" onload="this.media='all'">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    
    {% if extra_css %}
        {% for css_file in extra_css %}
        <link rel="stylesheet" href='{{ "/css/" + css_file | url }}'>
        {% endfor %}
    {% endif %}
</head>
<body>
    {% include "../components/header.njk" %}
    
    <main>
        {{ content | safe }}
    </main>
    
    {% include "../components/footer.njk" %}
    
    <!-- Scripts -->
    <!-- Ultra-minimalist approach - disable all JS to isolate scroll issue -->
    <!-- <script src="/js/script.js"></script> -->
    
    <!-- Basic scroll fix only -->
    <script>
        // Wait for page to fully load
        window.addEventListener('load', function() {
            // Remove all inline styles that might block scroll
            document.body.removeAttribute('style');
            document.documentElement.removeAttribute('style');
            
            // Remove any dynamic styles
            const dynamicStyles = document.querySelectorAll('style[data-dynamic]');
            dynamicStyles.forEach(style => style.remove());
            
            // Set basic scroll styles
            const basicStyle = document.createElement('style');
            basicStyle.textContent = `
                html, body {
                    overflow-x: hidden !important;
                    overflow-y: auto !important;
                    height: auto !important;
                    max-height: none !important;
                    position: static !important;
                    transform: none !important;
                    -webkit-transform: none !important;
                    touch-action: auto !important;
                    -webkit-overflow-scrolling: touch !important;
                    scroll-behavior: auto !important;
                }
                * {
                    touch-action: auto !important;
                }
            `;
            document.head.appendChild(basicStyle);
            
            // Simple viewport fix
            const viewport = document.querySelector('meta[name="viewport"]');
            if (viewport) {
                viewport.setAttribute('content', 'width=device-width, initial-scale=1.0, user-scalable=yes');
            }
        });
    </script>
    
    <!-- All JavaScript disabled to eliminate scroll conflicts
    <script src="/js/script.js"></script>
    <script src="/js/mobile-interactions.js"></script>
    -->
    
    {% if extra_js %}
        {% for js_file in extra_js %}
        <script src='{{ "/js/" + js_file | url }}'></script>
        {% endfor %}
    {% endif %}
    
    {% block scripts %}{% endblock %}
</body>
</html>
