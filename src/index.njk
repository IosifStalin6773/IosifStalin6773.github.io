<!-- Blog Section -->
<section id="blog" class="blog">
    <div class="container">
        <h2 class="section-title">Blog Técnico</h2>
        <div class="blog-grid">
            {% for post in collections.blog %}
            <article class="blog-card">
                <div class="blog-meta">
                    <span class="blog-category">{{ post.data.category }}</span>
                    <time datetime="{{ post.date | date('yyyy-MM-dd') }}" class="blog-date">
                        {{ post.date | date('dd MMMM yyyy') }}
                    </time>
                </div>
                <h3 class="blog-title">
                    <a href="{{ post.url }}">{{ post.data.title }}</a>
                </h3>
                <p class="blog-excerpt">{{ post.data.excerpt }}</p>
                <div class="blog-tags">
                    {% for tag in post.data.tags %}
                    <span class="tag">{{ tag }}</span>
                    {% endfor %}
                </div>
                <a href="{{ post.url }}" class="blog-link">Leer más <i class="fas fa-arrow-right"></i></a>
            </article>
            {% endfor %}
        </div>
        <div class="blog-cta">
            <a href="/blog/" class="btn btn-secondary">Ver Todos los Artículos</a>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="contact">
    <div class="container">
        <h2 class="section-title">Contacto</h2>
        <div class="contact-content">
            <div class="contact-info">
                <h3>Conectemos</h3>
                <p>
                    Si tienes un proyecto interesante o necesitas ayuda con desarrollo web, 
                    gaming scripts o automatización, no dudes en contactarme.
                </p>
                <div class="contact-methods">
                    <div class="contact-method">
                        <i class="fab fa-github"></i>
                        <div>
                            <h4>GitHub</h4>
                            <a href="{{ site.social.github }}" target="_blank" rel="noopener noreferrer">
                                {{ site.author.github }}
                            </a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <i class="fas fa-envelope"></i>
                        <div>
                            <h4>Email</h4>
                            <a href="mailto:{{ site.author.email }}">{{ site.author.email }}</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <i class="fab fa-linkedin"></i>
                        <div>
                            <h4>LinkedIn</h4>
                            <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener noreferrer">
                                Conectar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="contact-form">
                <form action="#" method="POST" class="form">
                    <div class="form-group">
                        <label for="name">Nombre</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="subject">Asunto</label>
                        <input type="text" id="subject" name="subject" required>
                    </div>
                    <div class="form-group">
                        <label for="message">Mensaje</label>
                        <textarea id="message" name="message" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Enviar Mensaje</button>
                </form>
            </div>
        </div>
    </div>
</section>
